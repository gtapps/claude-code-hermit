{
  "valid_expressions": [
    {
      "schedule": "0 4 * * *",
      "comment": "daily at 04:00",
      "matches": [
        {"time": "2026-04-08T04:00", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T05:00", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "30 8 * * 1-5",
      "comment": "weekdays at 08:30",
      "matches": [
        {"time": "2026-04-08T08:30", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-06T08:30", "dow": 0, "dom": 6, "expect": false},
        {"time": "2026-04-08T09:30", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "0 23 * * 0",
      "comment": "sundays at 23:00",
      "matches": [
        {"time": "2026-04-06T23:00", "dow": 0, "dom": 6, "expect": true},
        {"time": "2026-04-08T23:00", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "*/15 * * * *",
      "comment": "every 15 minutes",
      "matches": [
        {"time": "2026-04-08T00:00", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T00:15", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T00:07", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "0 9,14 * * *",
      "comment": "multi-fire same day at 09:00 and 14:00",
      "matches": [
        {"time": "2026-04-08T09:00", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T14:00", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T10:00", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "0 10 1,15 * *",
      "comment": "1st and 15th at 10:00",
      "matches": [
        {"time": "2026-04-01T10:00", "dow": 2, "dom": 1, "expect": true},
        {"time": "2026-04-15T10:00", "dow": 2, "dom": 15, "expect": true},
        {"time": "2026-04-08T10:00", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "0 10 * * 7",
      "comment": "DOW 7 = Sunday",
      "matches": [
        {"time": "2026-04-06T10:00", "dow": 0, "dom": 6, "expect": true},
        {"time": "2026-04-08T10:00", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "0 10 * * 0",
      "comment": "DOW 0 = Sunday",
      "matches": [
        {"time": "2026-04-06T10:00", "dow": 0, "dom": 6, "expect": true}
      ]
    },
    {
      "schedule": "0 10 31 * *",
      "comment": "DOM boundary — 31st",
      "matches": [
        {"time": "2026-03-31T10:00", "dow": 1, "dom": 31, "expect": true},
        {"time": "2026-04-08T10:00", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "09 04 * * *",
      "comment": "leading zeros accepted",
      "matches": [
        {"time": "2026-04-08T04:09", "dow": 2, "dom": 8, "expect": true}
      ]
    },
    {
      "schedule": "0 0 * * *",
      "comment": "midnight",
      "matches": [
        {"time": "2026-04-08T00:00", "dow": 2, "dom": 8, "expect": true}
      ]
    },
    {
      "schedule": "1-5/2 * * * *",
      "comment": "step on range: 1,3,5",
      "matches": [
        {"time": "2026-04-08T00:01", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T00:03", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T00:05", "dow": 2, "dom": 8, "expect": true},
        {"time": "2026-04-08T00:02", "dow": 2, "dom": 8, "expect": false},
        {"time": "2026-04-08T00:04", "dow": 2, "dom": 8, "expect": false}
      ]
    },
    {
      "schedule": "* * * * *",
      "comment": "every minute",
      "matches": [
        {"time": "2026-04-08T12:34", "dow": 2, "dom": 8, "expect": true}
      ]
    }
  ],
  "invalid_expressions": [
    {"schedule": "*/0 * * * *", "reason": "zero step"},
    {"schedule": "1-5/0 * * * *", "reason": "zero step on range"},
    {"schedule": "5-1 * * * *", "reason": "reverse range"},
    {"schedule": "1,,3 * * * *", "reason": "empty segment in list"},
    {"schedule": "60 * * * *", "reason": "minute out of range"},
    {"schedule": "* 24 * * *", "reason": "hour out of range"},
    {"schedule": "* * 0 * *", "reason": "DOM zero"},
    {"schedule": "* * 32 * *", "reason": "DOM out of range"},
    {"schedule": "* * * 0 *", "reason": "month zero"},
    {"schedule": "* * * 13 *", "reason": "month out of range"},
    {"schedule": "* * * * 8", "reason": "DOW out of range"},
    {"schedule": "0 10 15 * 1", "reason": "both DOM and DOW restricted"},
    {"schedule": "* * * *", "reason": "wrong field count — 4 fields"},
    {"schedule": "* * * * * *", "reason": "wrong field count — 6 fields"},
    {"schedule": "0 10 * * mon", "reason": "named day"},
    {"schedule": "0 10 * jan *", "reason": "named month"},
    {"schedule": "@daily", "reason": "macro"}
  ]
}
