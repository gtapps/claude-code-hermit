#!/usr/bin/env bash
# Stop the hermit Docker container gracefully.
# Run from project root: .claude-code-hermit/bin/hermit-docker-down [--force]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_DIR="$(cd "$AGENT_DIR/../.." && pwd)"
CONFIG="$AGENT_DIR/config.json"
COMPOSE="$PROJECT_DIR/docker-compose.hermit.yml"

if [ ! -f "$COMPOSE" ]; then
  echo "[hermit] No docker-compose.hermit.yml found in $PROJECT_DIR" >&2
  exit 1
fi

# Read tmux session name from config
TMUX_SESSION=$(python3 -c "
import json, sys, os
config = json.load(open(sys.argv[1]))
name = config.get('tmux_session_name', 'hermit-{project_name}')
project = os.path.basename(sys.argv[2])
print(name.replace('{project_name}', project))
" "$CONFIG" "$PROJECT_DIR" 2>/dev/null || echo "hermit")

# Read container service name from compose file
CONTAINER=$(python3 -c "
import sys
for line in open(sys.argv[1]):
    line = line.strip()
    if line.endswith(':') and not line.startswith('#') and line != 'services:' and line != 'volumes:':
        print(line.rstrip(':')); break
" "$COMPOSE" 2>/dev/null || echo "hermit")

FORCE=false
[ "${1:-}" = "--force" ] && FORCE=true

if [ "$FORCE" = false ]; then
  # Graceful shutdown: send session-close via tmux, then stop container
  echo "[hermit] Requesting graceful session close..."
  cd "$PROJECT_DIR" && docker compose -f docker-compose.hermit.yml exec -T "$CONTAINER" \
    tmux send-keys -t "$TMUX_SESSION:0.0" "/claude-code-hermit:session-close --shutdown" Enter 2>/dev/null || true

  # Wait for session to close (up to 60s)
  echo "[hermit] Waiting for session to close (up to 60s)..."
  for i in $(seq 1 60); do
    STATUS=$(cd "$PROJECT_DIR" && docker compose -f docker-compose.hermit.yml exec -T "$CONTAINER" \
      cat .claude-code-hermit/.status 2>/dev/null || echo "unknown")
    if [ "$STATUS" = "idle" ] || [ "$STATUS" = "shutdown" ]; then
      echo "[hermit] Session closed after ${i}s."
      break
    fi
    sleep 1
  done
fi

echo "[hermit] Stopping Docker container..."
cd "$PROJECT_DIR" && docker compose -f docker-compose.hermit.yml down

echo "[hermit] Container stopped."
