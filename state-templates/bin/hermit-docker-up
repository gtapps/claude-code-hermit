#!/usr/bin/env bash
# Start the hermit Docker container and show how to attach.
# Run from project root: .claude-code-hermit/bin/hermit-docker-up
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_DIR="$(cd "$AGENT_DIR/../.." && pwd)"
CONFIG="$AGENT_DIR/config.json"
COMPOSE="$PROJECT_DIR/docker-compose.hermit.yml"

if [ ! -f "$COMPOSE" ]; then
  echo "[hermit] No docker-compose.hermit.yml found in $PROJECT_DIR" >&2
  echo "[hermit] Run /claude-code-hermit:docker-setup inside Claude Code first." >&2
  exit 1
fi

# Read tmux session name from config
TMUX_SESSION=$(python3 -c "
import json, sys, os
config = json.load(open(sys.argv[1]))
name = config.get('tmux_session_name', 'hermit-{project_name}')
project = os.path.basename(sys.argv[2])
print(name.replace('{project_name}', project))
" "$CONFIG" "$PROJECT_DIR" 2>/dev/null || echo "hermit")

# Read container service name from compose file
CONTAINER=$(python3 -c "
import sys
for line in open(sys.argv[1]):
    line = line.strip()
    if line.endswith(':') and not line.startswith('#') and line != 'services:' and line != 'volumes:':
        print(line.rstrip(':')); break
" "$COMPOSE" 2>/dev/null || echo "hermit")

echo "[hermit] Starting Docker container..."
cd "$PROJECT_DIR" && docker compose -f docker-compose.hermit.yml up -d --build

echo ""
echo "Container is up. To connect to the hermit's tmux session:"
echo ""
echo "  docker compose -f docker-compose.hermit.yml exec $CONTAINER tmux attach -t $TMUX_SESSION"
echo ""
echo "Detach with: Ctrl+B then D"
echo "Status: .claude-code-hermit/bin/hermit-status"
