#!/usr/bin/env bash
# Dispatcher for hermit boot scripts — resolves plugin path from config.json
# Usage: hermit-run <script.py> [args...]
# Called by hermit-start and hermit-stop wrappers.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="$SCRIPT_DIR/../config.json"
TARGET="${1:?Usage: hermit-run <script.py> [args...]}"
shift

if [ ! -f "$CONFIG" ]; then
  echo "[hermit] No config found at $CONFIG" >&2
  echo "[hermit] Run /claude-code-hermit:hermit-init inside Claude Code first." >&2
  exit 1
fi

# --- Docker subcommands (handled directly in bash, no plugin root needed) ---

if [ "$TARGET" = "docker-up" ] || [ "$TARGET" = "docker-down" ]; then
  PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
  COMPOSE="$PROJECT_DIR/docker-compose.hermit.yml"
  STATUS_FILE="$PROJECT_DIR/.claude-code-hermit/.status"

  if [ ! -f "$COMPOSE" ]; then
    echo "[hermit] No docker-compose.hermit.yml found in $PROJECT_DIR" >&2
    echo "[hermit] Run /claude-code-hermit:docker-setup inside Claude Code first." >&2
    exit 1
  fi

  # Resolve tmux session name from config
  TMUX_SESSION=$(python3 -c "
import json, sys, os
config = json.load(open(sys.argv[1]))
name = config.get('tmux_session_name', 'hermit-{project_name}')
project = os.path.basename(sys.argv[2])
print(name.replace('{project_name}', project))
" "$CONFIG" "$PROJECT_DIR" 2>/dev/null || echo "hermit")

  # Get compose service name from docker compose itself
  SERVICE=$(cd "$PROJECT_DIR" && docker compose -f "$COMPOSE" config --services 2>/dev/null | head -1 || echo "hermit")

  DC=(docker compose -f "$COMPOSE")

  if [ "$TARGET" = "docker-up" ]; then
    echo "[hermit] Starting Docker container..."
    cd "$PROJECT_DIR" && "${DC[@]}" up -d "$@"
    echo ""
    echo "Container is up. To connect to the hermit's tmux session:"
    echo ""
    echo "  docker compose -f docker-compose.hermit.yml exec $SERVICE tmux attach -t $TMUX_SESSION"
    echo ""
    echo "Detach with: Ctrl+B then D"
    echo "Status: .claude-code-hermit/bin/hermit-status"
  else
    # docker-down
    FORCE=false
    [ "${1:-}" = "--force" ] && FORCE=true

    if [ "$FORCE" = false ]; then
      echo "[hermit] Requesting graceful session close..."
      cd "$PROJECT_DIR" && "${DC[@]}" exec -T "$SERVICE" \
        tmux send-keys -t "$TMUX_SESSION:0.0" "/claude-code-hermit:session-close --shutdown" Enter 2>/dev/null || true

      # Poll the host-side status file (project dir is bind-mounted)
      echo "[hermit] Waiting for session to close (up to 60s)..."
      CLOSED=false
      for i in $(seq 1 60); do
        STATUS=$(cat "$STATUS_FILE" 2>/dev/null || echo "unknown")
        if [ "$STATUS" = "idle" ] || [ "$STATUS" = "shutdown" ]; then
          echo "[hermit] Session closed after ${i}s."
          CLOSED=true
          break
        fi
        sleep 1
      done
      if [ "$CLOSED" = false ]; then
        echo "[hermit] Timed out waiting for graceful close; forcing stop." >&2
      fi
    fi

    echo "[hermit] Stopping Docker container..."
    cd "$PROJECT_DIR" && "${DC[@]}" down
    echo "[hermit] Container stopped."
  fi
  exit 0
fi

# Prefer HERMIT_PLUGIN_ROOT env var (set by docker-entrypoint) over config.json _plugin_root.
# Inside a container, _plugin_root points to the host path which doesn't exist.
if [ -n "${HERMIT_PLUGIN_ROOT:-}" ] && [ -d "$HERMIT_PLUGIN_ROOT" ]; then
  PLUGIN_ROOT="$HERMIT_PLUGIN_ROOT"
else
  PLUGIN_ROOT=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('_plugin_root',''))" "$CONFIG")
fi

# If stored path doesn't exist, try remapping the /.claude/ suffix to the current
# environment's config dir. This handles two cases:
#   1. Running in Docker with CLAUDE_CONFIG_DIR set (host path → container path)
#   2. Running on host after init was last run in Docker (container path → host path)
# We never write back — _plugin_root must remain portable across both environments.
if [ -n "$PLUGIN_ROOT" ] && [ ! -d "$PLUGIN_ROOT" ]; then
  SUFFIX="${PLUGIN_ROOT#*/.claude/}"
  if [ "$SUFFIX" != "$PLUGIN_ROOT" ]; then
    # Try CLAUDE_CONFIG_DIR first (explicit container isolation)
    if [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
      REMAPPED="${CLAUDE_CONFIG_DIR}/${SUFFIX}"
      if [ -d "$REMAPPED" ]; then
        PLUGIN_ROOT="$REMAPPED"
        echo "[hermit] Plugin path remapped to container config: $PLUGIN_ROOT" >&2
      fi
    fi
    # Try current user's ~/.claude (host↔Docker cross-environment move)
    if [ ! -d "$PLUGIN_ROOT" ]; then
      REMAPPED="${HOME}/.claude/${SUFFIX}"
      if [ -d "$REMAPPED" ]; then
        PLUGIN_ROOT="$REMAPPED"
        echo "[hermit] Plugin path remapped to home: $PLUGIN_ROOT" >&2
      fi
    fi
  fi
fi

# Auto-discover new version directory when stored path is stale after plugin upgrade
if [ -n "$PLUGIN_ROOT" ] && [ ! -d "$PLUGIN_ROOT" ]; then
  PARENT_DIR="$(dirname "$PLUGIN_ROOT")"
  if [ -d "$PARENT_DIR" ]; then
    LATEST=""
    for d in "$PARENT_DIR"/*/; do
      # Verify directory has both scripts/ and a valid plugin.json with the correct name
      if [ -d "$d/scripts" ] && [ -f "$d/.claude-plugin/plugin.json" ]; then
        FOUND_NAME=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('name',''))" "$d/.claude-plugin/plugin.json" 2>/dev/null)
        [ "$FOUND_NAME" = "claude-code-hermit" ] && LATEST="$d"
      fi
    done
    if [ -n "$LATEST" ]; then
      PLUGIN_ROOT="${LATEST%/}"
      echo "[hermit] Plugin updated — resolved new path: $PLUGIN_ROOT" >&2
      python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    cfg = json.load(f)
cfg['_plugin_root'] = sys.argv[2]
with open(sys.argv[1], 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
" "$CONFIG" "$PLUGIN_ROOT" 2>/dev/null || echo "[hermit] Warning: could not update config.json with new path" >&2
    fi
  fi
fi

if [ -z "$PLUGIN_ROOT" ] || [ ! -d "$PLUGIN_ROOT" ]; then
  echo "[hermit] Plugin root not found or invalid: $PLUGIN_ROOT" >&2
  echo "[hermit] Run /claude-code-hermit:hermit-upgrade inside Claude Code to fix." >&2
  exit 1
fi

SCRIPT="$PLUGIN_ROOT/scripts/$TARGET"
if [ ! -f "$SCRIPT" ]; then
  echo "[hermit] $TARGET not found at $PLUGIN_ROOT/scripts/" >&2
  echo "[hermit] Plugin may be corrupted. Reinstall with: claude plugin install claude-code-hermit@claude-code-hermit --scope project" >&2
  exit 1
fi

exec python3 "$SCRIPT" "$@"
