#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(pwd)"
AGENT_DIR="${PROJECT_DIR}/.claude-code-hermit"
CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-/home/claude/.claude}"

echo "[docker-entrypoint] Starting hermit container..."
echo "[docker-entrypoint] Project: ${PROJECT_DIR}"

# --- 1. Bypass onboarding, pre-approve MCP servers, patch permission_mode ---
CLAUDE_JSON="${CLAUDE_CONFIG_DIR}/.claude.json"
CC_VERSION=$(claude --version 2>/dev/null | grep -oP '[\d.]+' | head -1 || echo "0.0.0")
CHANNELS=$(python3 -c "
import json, sys, os
claude_json, version, project = sys.argv[1], sys.argv[2], sys.argv[3]

# --- .claude.json: onboarding + MCP approval ---
if os.path.exists(claude_json):
    with open(claude_json) as f: d = json.load(f)
else:
    d = {}
changed = False

if not d.get('hasCompletedOnboarding') or d.get('lastOnboardingVersion') != version:
    d.update({'hasCompletedOnboarding': True, 'lastOnboardingVersion': version})
    changed = True
    print(f'[docker-entrypoint] Onboarding bypass set for Claude Code v{version}', file=sys.stderr)

config_path = os.path.join(project, '.claude-code-hermit', 'config.json')
channels = []
if os.path.exists(config_path):
    with open(config_path) as f: cfg = json.load(f)
    channels = cfg.get('channels', [])
if channels:
    plugin_ids = {
        'discord': 'plugin:discord:discord',
        'telegram': 'plugin:telegram:telegram',
    }
    proj = d.setdefault('projects', {}).setdefault(project, {})
    enabled = proj.get('enabledMcpjsonServers', [])
    disabled_json = proj.get('disabledMcpjsonServers', [])
    disabled_mcp = proj.get('disabledMcpServers', [])
    for ch in channels:
        pid = plugin_ids.get(ch)
        if not pid:
            continue
        if pid not in enabled:
            enabled.append(pid)
            changed = True
            print(f'[docker-entrypoint] MCP server {pid}: added to enabledMcpjsonServers', file=sys.stderr)
        if pid in disabled_json:
            disabled_json.remove(pid)
            changed = True
        if pid in disabled_mcp:
            disabled_mcp.remove(pid)
            changed = True
    proj['enabledMcpjsonServers'] = enabled
    proj['disabledMcpjsonServers'] = disabled_json
    proj['disabledMcpServers'] = disabled_mcp

if changed:
    with open(claude_json, 'w') as f: json.dump(d, f)

# --- config.json: force bypassPermissions ---
if os.path.exists(config_path):
    if cfg.get('permission_mode') != 'bypassPermissions':
        cfg['permission_mode'] = 'bypassPermissions'
        with open(config_path, 'w') as f: json.dump(cfg, f, indent=2)
        print('[docker-entrypoint] permission_mode -> bypassPermissions', file=sys.stderr)
    else:
        print('[docker-entrypoint] permission_mode OK', file=sys.stderr)

# Emit channel list on stdout for the shell to capture
print(' '.join(ch for ch in channels if ch != 'imessage'))
" "$CLAUDE_JSON" "$CC_VERSION" "$PROJECT_DIR")

# --- 2. Symlink channel state dirs ---
for var_name in DISCORD_STATE_DIR TELEGRAM_STATE_DIR; do
  local_dir="${!var_name:-}"
  if [ -n "$local_dir" ]; then
    plugin="${var_name%%_STATE_DIR}"
    plugin="${plugin,,}"
    global_dir="${CLAUDE_CONFIG_DIR}/channels/${plugin}"
    if [ -L "$global_dir" ] && [ "$(readlink "$global_dir")" = "$local_dir" ]; then
      : # already correct
    else
      mkdir -p "$(dirname "$global_dir")" "$local_dir"
      rm -rf "$global_dir"
      ln -s "$local_dir" "$global_dir"
      echo "[docker-entrypoint] Symlinked ${global_dir} -> ${local_dir}"
    fi
  fi
done

# --- 3. Install channel plugins (named volume starts empty on first run) ---
if [ -n "$CHANNELS" ]; then
  INSTALLED=$(claude plugin list 2>/dev/null || echo "")
  for plugin in $CHANNELS; do
    if ! echo "$INSTALLED" | grep -q "${plugin}@claude-plugins-official"; then
      echo "[docker-entrypoint] Installing channel plugin: ${plugin}"
      claude plugin install "${plugin}@claude-plugins-official" --scope local 2>/dev/null || \
        echo "[docker-entrypoint] Warning: failed to install ${plugin} plugin — install manually"
    fi
  done
fi

# --- 4. Launch hermit-start ---
"${AGENT_DIR}/bin/hermit-start" "$@"

# --- 5. Keep PID 1 alive ---
SESSION_NAME="{{TMUX_SESSION_NAME}}"
echo "[docker-entrypoint] Watching tmux session: ${SESSION_NAME}"
while tmux has-session -t "$SESSION_NAME" 2>/dev/null; do
  sleep 30
done
echo "[docker-entrypoint] tmux session ended — container exiting"
