services:
  hermit:
    build:
      context: .
      dockerfile: Dockerfile.hermit
      args:
        HOST_UID: ${UID:-1000}
    volumes:
      - ${PWD}:${PWD}
      # Isolated config volume — container gets its own Claude Code config
      # (onboarding, plugins, auto-memory) instead of sharing the host's.
      # Persists across restarts. First run is slower (onboarding + plugin install).
      - claude-config:/home/claude/.claude
    working_dir: ${PWD}
    env_file: .env
    environment:
      - CLAUDE_CONFIG_DIR=/home/claude/.claude
      - {{AUTH_ENV_LINE}}
{{CHANNEL_ENV_LINES}}
    network_mode: host
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "tmux", "has-session", "-t", "{{TMUX_SESSION_NAME}}"]
      interval: 60s
      timeout: 5s
      retries: 3
      start_period: 30s

volumes:
  claude-config:
