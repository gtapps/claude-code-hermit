services:
  hermit:
    build:
      context: .
      dockerfile: Dockerfile.hermit
      args:
        HOST_UID: ${UID:-1000}
    volumes:
      - ${PWD}:${PWD}
      # Isolated config volume — container gets its own Claude Code config
      # (onboarding, plugins, auto-memory) instead of sharing the host's.
      # Persists across restarts. First run is slower (onboarding + plugin install).
      - claude-config:/home/claude/.claude
      # Git identity — read-only so commits have the right author name/email.
      # Remove this line if the host has no ~/.gitconfig.
      - ${HOME}/.gitconfig:/home/claude/.gitconfig:ro
{{CHANNEL_VOLUME_LINES}}
    working_dir: ${PWD}
    env_file: .env
    environment:
      - CLAUDE_CONFIG_DIR=/home/claude/.claude
      - NODE_OPTIONS=--max-old-space-size=4096
      - AGENT_HOOK_PROFILE={{AGENT_HOOK_PROFILE}}
{{AUTH_ENV_LINE}}{{CHANNEL_ENV_LINES}}
{{NETWORK_MODE_LINE}}
    restart: unless-stopped
    # Give the entrypoint's SIGTERM trap (30-iteration graceful session-close poll)
    # time to finish before Docker escalates to SIGKILL. Default is 10s which is
    # not enough for session-close to complete cleanly.
    stop_grace_period: 60s
    healthcheck:
      test: ["CMD", "tmux", "has-session", "-t", "{{TMUX_SESSION_NAME}}"]
      interval: 60s
      timeout: 5s
      retries: 3
      start_period: 30s

volumes:
  claude-config:
