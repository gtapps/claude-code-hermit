## Recent Sessions
```dataview
TABLE date, task, status
FROM ".claude-code-hermit/sessions"
WHERE id
SORT date DESC
LIMIT 5
```

## Active Proposals
```dataview
TABLE title, status, category
FROM ".claude-code-hermit/proposals"
WHERE id AND (status = "proposed" OR status = "accepted")
SORT id ASC
```

## Reflect Health
```dataviewjs
try {
  const raw = await app.vault.adapter.read(".claude-code-hermit/state/reflection-state.json");
  const c = JSON.parse(raw).counters;
  if (!c || c.total_runs === 0) {
    const since = (c && c.since) ? c.since.slice(0, 10) : "—";
    dv.paragraph(`_No runs yet (since ${since})_`);
  } else {
    const since = c.since ? c.since.slice(0, 10) : "—";
    const lastRun = c.last_run_at ? c.last_run_at.slice(0, 10) : "—";
    const emptyPct = Math.round((c.empty_runs / c.total_runs) * 100);
    dv.paragraph(
      `**Runs:** ${c.total_runs} total, ${c.empty_runs} empty (${emptyPct}%) | since ${since} | last ${lastRun}  \n` +
      `**Candidates:** ${c.runs_with_candidates} runs with candidates | judge: ${c.judge_accept} accepted / ${c.judge_downgrade} downgraded / ${c.judge_suppress} suppressed` +
      (c.proposals_created > 0 || c.micro_proposals_queued > 0
        ? `  \n**Output:** ${c.proposals_created} proposals created, ${c.micro_proposals_queued} micro queued`
        : "")
    );
  }
} catch {
  dv.paragraph("_No counter data — run reflect once to populate._");
}
```

## Recent Artifacts
```dataviewjs
try {
  const raw = await app.vault.adapter.read(".claude-code-hermit/cortex-manifest.json");
  const manifest = JSON.parse(raw);
  const paths = (manifest.artifact_paths || []).filter(p => typeof p === "string");
  if (paths.length === 0) {
    dv.paragraph("_No artifact paths configured. Run `/claude-code-hermit:obsidian-setup --reconfigure-manifest` to set up._");
  } else {
    const pages = dv.pages(paths.map(p => `"${p}"`).join(" OR "))
      .where(p => p.created)
      .sort(p => p.created, "desc")
      .limit(5);
    if (pages.length === 0) {
      dv.paragraph("_No artifacts with frontmatter found._");
    } else {
      dv.list(pages.map(p => `[[${p.file.name}]]${p.title ? " — " + p.title : ""}`));
    }
  }
} catch {
  dv.paragraph("_No cortex-manifest.json — run `/claude-code-hermit:obsidian-setup` to configure._");
}
```

