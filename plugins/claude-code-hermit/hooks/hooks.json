{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/pause-gate.ts"],
            "timeout": 3
          }
        ],
        "description": "Deny every tool call while state/pause.json is set (PROP-015), except a channel reply tool and PushNotification"
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/enforce-deny-patterns.ts"],
            "timeout": 3
          }
        ],
        "description": "Enforce deny-patterns (always_on incl. OPERATOR.md only when AGENT_HOOK_PROFILE=strict), warn on template edits"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/cache-edit-guard.ts"],
            "timeout": 3
          }
        ],
        "description": "Warn (or block, with HERMIT_CACHE_GUARD=block) when editing a marketplace cache copy whose runtime source is canonical"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(discord|telegram|imessage).*reply",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/channel-hook.ts"],
            "timeout": 5
          }
        ],
        "description": "Persist dm_channel_id to config.json after channel reply"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"${HERMIT_DEV_MODE:-}\" ] && exit 0; INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r \".tool_input.file_path // empty\"); if [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && echo \"$FILE\" | grep -qF \"$CLAUDE_PLUGIN_ROOT\" && echo \"$FILE\" | grep -qE \"scripts/|hooks/\"; then bun test \"${CLAUDE_PLUGIN_ROOT}/tests\" 2>&1 | tail -5; fi'",
            "timeout": 30
          }
        ],
        "description": "Run contract tests after script/hook edits (dev mode only: set HERMIT_DEV_MODE=1). Stays in shell form: uses stdin/jq/pipes; convert by porting to Node, not by switching to args:[]."
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/validate-config.ts"],
            "timeout": 5,
            "continueOnBlock": true
          }
        ],
        "description": "Validate config.json schema after edits"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/generate-summary.ts"],
            "timeout": 5
          }
        ],
        "description": "Regenerate state-summary.md after state/ file edits"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/prompt-context.ts"]
          }
        ],
        "description": "Inject current local time before every prompt so the model never anchors to a stale 'now'"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/channel-reply-reminder.ts"],
            "timeout": 3
          }
        ],
        "description": "Inject reply-tool reminder when inbound prompt starts with a <channel source=...> envelope"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/record-operator-action.ts"],
            "timeout": 3
          }
        ],
        "description": "Record last operator-action timestamp; skips routine/loop/channel prompts"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/pause-keyword.ts"],
            "timeout": 3
          }
        ],
        "description": "Deterministic pause/resume/snooze keyword writer (PROP-015) — writes state/pause.json before any model turn, gated by the channel's allowed_users"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/channel-status-responder.ts"],
            "timeout": 12
          }
        ],
        "description": "Deterministic status responder — send-then-block reply to an exact idle 'status' message, gated by the channel's allowed_users; never fires on a near-miss or mid-turn arrival"
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/startup-context.ts"]
          }
        ],
        "description": "Load session context on startup"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/record-operator-action.ts"],
            "timeout": 3
          }
        ],
        "description": "Reset last-operator-action clock on session start"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/stop-pipeline.ts"],
            "timeout": 15
          }
        ],
        "description": "Stop pipeline: cost tracking, compact suggestion, session diff, evaluation, heartbeat"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/subagent-cost.ts"],
            "timeout": 10
          }
        ],
        "description": "Capture async-dispatched subagent token cost (invisible to Stop-time cost-tracker)"
      }
    ]
  }
}
