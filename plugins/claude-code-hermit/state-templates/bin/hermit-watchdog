#!/usr/bin/env bash
# Single-shot hermit watchdog — dead-session restart, wedge detection, re-arm fallback.
# Run from project root: .claude-code-hermit/bin/hermit-watchdog [run|install|uninstall]
# Subcommands:
#   run        (default) — one decision cycle; exit 0 always
#   install    — install OS scheduler timer (systemd/launchd/cron)
#   uninstall  — remove the installed timer
exec "$(dirname "$0")/hermit-run" hermit-watchdog "$@"
