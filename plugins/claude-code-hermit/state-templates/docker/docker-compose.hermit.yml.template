services:
  hermit:
    build:
      context: .
      dockerfile: Dockerfile.hermit
      args:
        HOST_UID: ${UID:-1000}
        CLAUDE_CODE_VERSION: ${CLAUDE_CODE_VERSION:-latest}
    volumes:
      # NOTE: ${PWD} is evaluated from the shell's CWD when `docker compose` runs.
      # Normal operation: use `.claude-code-hermit/bin/hermit-docker up` (it cd's to the
      # project root first). Direct `docker compose -f docker-compose.hermit.yml up` is safe
      # only from the project root — launching from any other directory mounts the wrong tree.
      - ${PWD}:${PWD}
      # Isolated config volume — container gets its own Claude Code config
      # (onboarding, plugins, auto-memory) instead of sharing the host's.
      # Persists across restarts. First run is slower (onboarding + plugin install).
      - claude-config:/home/claude/.claude
      # Git identity — read-only so commits have the right author name/email.
      # Remove this line if the host has no ~/.gitconfig.
      - ${HOME}/.gitconfig:/home/claude/.gitconfig:ro
{{CHANNEL_VOLUME_LINES}}
    working_dir: ${PWD}
    env_file: .env
    environment:
      - CLAUDE_CONFIG_DIR=/home/claude/.claude
      - NODE_OPTIONS=--max-old-space-size=4096
      - AGENT_HOOK_PROFILE={{AGENT_HOOK_PROFILE}}
      - GH_TOKEN=${HERMIT_GH_TOKEN:-}
{{AUTH_ENV_LINE}}{{CHANNEL_ENV_LINES}}
{{NETWORK_MODE_LINE}}
    # Defense in depth — rationale and override path: run /claude-code-hermit:docker-security.
    cap_drop:
      - ALL
    # Load-bearing: blocks setuid escalation even from a planted binary in a compromised plugin.
    security_opt:
      - no-new-privileges:true
    # Caps fork-bombs; 2048 covers npm install bursts (cgroup v2 counts threads as PIDs).
    pids_limit: 2048
    restart: unless-stopped
    # Give the entrypoint's SIGTERM trap (30-iteration graceful session-close poll)
    # time to finish before Docker escalates to SIGKILL. Default is 10s which is
    # not enough for session-close to complete cleanly.
    stop_grace_period: 60s
    healthcheck:
      # {{TMUX_SESSION_NAME}} is substituted at render time by /docker-setup. Unlike the
      # entrypoint (which is raw-copied on upgrade and resolves the name at runtime), this
      # compose file is always regenerated by the wizard, so a build-time placeholder is safe.
      test: ["CMD", "tmux", "has-session", "-t", "{{TMUX_SESSION_NAME}}"]
      interval: 60s
      timeout: 5s
      retries: 3
      start_period: 30s

volumes:
  claude-config:
