#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if ! command -v bun >/dev/null 2>&1; then
  printf 'Error: bun not found on PATH. Install it from https://bun.sh (required by claude-code-hermit core).\n' >&2
  exit 1
fi

exec bun "${PLUGIN_ROOT}/src/cli.ts" "$@"
